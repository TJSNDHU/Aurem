{% comment %}
  ORA Recommendations — AUREM AI Product Cards
  App Block: Merchants drag-and-drop into theme sections
  Fetches personalized recommendations via App Proxy from AUREM backend
{% endcomment %}

{% schema %}
{
  "name": "AUREM Recommended For You",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "aurem_backend_url",
      "label": "AUREM Backend URL",
      "default": "https://your-aurem-instance.com"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Recommended For You"
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Products to Show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#D4AF37"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "glass", "label": "Glassmorphism (Dark)" },
        { "value": "clean", "label": "Clean (Light)" }
      ],
      "default": "clean"
    }
  ]
}
{% endschema %}

<style>
  .ora-recs-section {
    padding: 48px 24px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .ora-recs-header {
    text-align: center;
    margin-bottom: 32px;
  }
  .ora-recs-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 12px;
    background: {{ block.settings.accent_color }}12;
    color: {{ block.settings.accent_color }};
    border: 1px solid {{ block.settings.accent_color }}25;
  }
  .ora-recs-badge svg { width: 12px; height: 12px; fill: {{ block.settings.accent_color }}; }
  .ora-recs-title {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.5px;
    margin: 0;
  }
  .ora-recs-grid {
    display: grid;
    grid-template-columns: repeat({{ block.settings.product_count | at_most: 4 }}, 1fr);
    gap: 20px;
  }
  @media (max-width: 768px) {
    .ora-recs-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .ora-recs-title { font-size: 22px; }
  }
  @media (max-width: 480px) {
    .ora-recs-grid { grid-template-columns: 1fr 1fr; }
  }

  {% if block.settings.card_style == 'glass' %}
  .ora-rec-card {
    background: rgba(15, 15, 15, 0.65);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s;
    text-decoration: none;
    color: #E8E4DE;
    display: block;
  }
  .ora-rec-card:hover {
    border-color: {{ block.settings.accent_color }}33;
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.3);
  }
  .ora-rec-info { padding: 14px; }
  .ora-rec-title { font-size: 13px; font-weight: 600; color: #E8E4DE; margin: 0 0 4px; }
  .ora-rec-reason { font-size: 10px; color: {{ block.settings.accent_color }}; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .ora-rec-price { font-size: 16px; font-weight: 800; color: {{ block.settings.accent_color }}; }
  {% else %}
  .ora-rec-card {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.3s;
    text-decoration: none;
    color: #1A1A2E;
    display: block;
  }
  .ora-rec-card:hover {
    border-color: {{ block.settings.accent_color }};
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.08);
  }
  .ora-rec-info { padding: 14px; }
  .ora-rec-title { font-size: 13px; font-weight: 600; color: #1A1A2E; margin: 0 0 4px; }
  .ora-rec-reason { font-size: 10px; color: {{ block.settings.accent_color }}; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
  .ora-rec-price { font-size: 16px; font-weight: 800; color: #1A1A2E; }
  {% endif %}

  .ora-rec-img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    display: block;
  }
  .ora-rec-img-placeholder {
    width: 100%;
    aspect-ratio: 1;
    background: linear-gradient(135deg, {{ block.settings.accent_color }}12, {{ block.settings.accent_color }}06);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ora-rec-img-placeholder svg { width: 32px; height: 32px; stroke: {{ block.settings.accent_color }}44; fill: none; stroke-width: 1.5; }

  .ora-recs-loading {
    text-align: center;
    padding: 40px;
    color: #888;
    font-size: 13px;
  }
  .ora-powered {
    text-align: center;
    margin-top: 20px;
    font-size: 9px;
    color: #aaa;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
</style>

<section class="ora-recs-section" id="ora-recs-section">
  <div class="ora-recs-header">
    <div class="ora-recs-badge">
      <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      AUREM AI
    </div>
    <h2 class="ora-recs-title">{{ block.settings.heading }}</h2>
  </div>
  <div class="ora-recs-grid" id="ora-recs-grid">
    <div class="ora-recs-loading" id="ora-recs-loading">Loading recommendations...</div>
  </div>
  <div class="ora-powered">Powered by AUREM AI</div>
</section>

<script>
(function() {
  var AUREM_URL = {{ block.settings.aurem_backend_url | json }};
  var limit = {{ block.settings.product_count }};
  var grid = document.getElementById('ora-recs-grid');
  var loading = document.getElementById('ora-recs-loading');
  var shop = window.Shopify ? window.Shopify.shop : '';

  function renderCard(product) {
    var card = document.createElement('a');
    card.className = 'ora-rec-card';
    card.href = product.handle ? '/products/' + product.handle : '#';

    var imgHtml = product.image_url
      ? '<img class="ora-rec-img" src="' + product.image_url + '" alt="' + (product.title || '') + '" loading="lazy" />'
      : '<div class="ora-rec-img-placeholder"><svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg></div>';

    card.innerHTML = imgHtml +
      '<div class="ora-rec-info">' +
        '<div class="ora-rec-reason">' + (product.reason || 'Recommended') + '</div>' +
        '<h3 class="ora-rec-title">' + (product.title || 'Product') + '</h3>' +
        '<div class="ora-rec-price">$' + (product.price || '0.00') + '</div>' +
      '</div>';

    return card;
  }

  fetch(AUREM_URL + '/api/shopify-app/proxy/recommendations?shop=' + encodeURIComponent(shop) + '&limit=' + limit)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (loading) loading.remove();
      var recs = data.recommendations || [];
      if (recs.length === 0) {
        grid.innerHTML = '<div class="ora-recs-loading">No recommendations available yet</div>';
        return;
      }
      recs.forEach(function(p) {
        grid.appendChild(renderCard(p));
      });
    })
    .catch(function() {
      if (loading) loading.textContent = 'Recommendations unavailable';
    });
})();
</script>
