# =============================================================================
# AUREM PROJECT - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env with real keys to version control
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
MONGO_URL="mongodb://localhost:27017"
DB_NAME=your_database_name

# -----------------------------------------------------------------------------
# CORS & SECURITY
# -----------------------------------------------------------------------------
CORS_ORIGINS="*"
JWT_SECRET=your-jwt-secret-key-here

# -----------------------------------------------------------------------------
# AUREM PLATFORM KEYS (Required for AUREM AI Platform)
# -----------------------------------------------------------------------------
AUREM_ENCRYPTION_KEY=your-32-character-encryption-key
AUREM_ADMIN_EMAIL=admin@yourdomain.com
AUREM_ADMIN_PASSWORD=your-admin-password

# -----------------------------------------------------------------------------
# LLM PROVIDERS
# -----------------------------------------------------------------------------
# Emergent Universal Key (works for OpenAI, Claude, Gemini)
EMERGENT_LLM_KEY=sk-emergent-your-key-here

# Alternative: Direct API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# -----------------------------------------------------------------------------
# PAYMENT PROVIDERS
# -----------------------------------------------------------------------------
# Stripe
STRIPE_API_KEY=sk_test_your-stripe-key

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox

# Bambora (Canada)
BAMBORA_MERCHANT_ID=your-merchant-id
BAMBORA_API_PASSCODE=your-api-passcode

# -----------------------------------------------------------------------------
# COMMUNICATION SERVICES
# -----------------------------------------------------------------------------
# Twilio (SMS, Voice, WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_VERIFY_SERVICE_SID=your-verify-service-sid
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+1234567890

# WhatsApp Business API (WHAPI)
WHAPI_API_TOKEN=your-whapi-token
WHAPI_API_URL=https://gate.whapi.cloud

# Email Service
SENDER_EMAIL=support@yourdomain.com

# -----------------------------------------------------------------------------
# MEDIA & CDN
# -----------------------------------------------------------------------------
# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ImgBB
IMGBB_API_KEY=your-imgbb-key

# -----------------------------------------------------------------------------
# SHIPPING
# -----------------------------------------------------------------------------
# FlagShip (Canada Shipping)
FLAGSHIP_API_TOKEN=your-flagship-token
FLAGSHIP_API_URL=https://api.smartship.io
FLAGSHIP_ENV=test

# -----------------------------------------------------------------------------
# AI & ML SERVICES
# -----------------------------------------------------------------------------
# ElevenLabs (Voice AI)
ELEVENLABS_API_KEY=your-elevenlabs-key

# HeyGen (Talking Avatar)
HEYGEN_API_KEY=your-heygen-key

# OpenWeather (Weather Data for Site Audit)
OPENWEATHER_API_KEY=your-openweather-key

# -----------------------------------------------------------------------------
# GOOGLE SERVICES
# -----------------------------------------------------------------------------
# OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Places API
GOOGLE_PLACES_API_KEY=your-places-api-key

# Business Review
GOOGLE_REVIEW_LINK=https://g.page/r/your-review-link

# Emergent Auth Service
AUTH_SERVICE_URL=https://demobackend.emergentagent.com
