# ─────────────────────────────────────────────────────────────
# AUREM Platform — .gitignore
# ─────────────────────────────────────────────────────────────
# NOTE: `.env` files are intentionally TRACKED by git.
# The Emergent deployment pipeline overwrites them with
# production values at deploy time. Do NOT re-add `.env` here.
# ─────────────────────────────────────────────────────────────

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Virtual envs
venv/
.venv/
env/

# Sensitive identity / memory files (founder profile, internal notes)
ORA_MEMORY.md
backend/identity/
memory/test_credentials.md
memory/ORA_MEMORY.md

# Runtime artifacts (NOT code) — these bloat the repo
.screenshots/
test_reports/
htmlcov/
.coverage
.pytest_cache/
backend/data/lightrag_store/
backend/uploads/
backend/graphify-out/

# Redis snapshot — runtime state, never commit (bloats repo, leaks data)
dump.rdb
*.rdb
appendonly.aof
backend/.chromadb/
backend/chromadb/
backend/.chroma/
backend/static/admin/

# Legacy / dead code archives
backup_original/

# Internal Emergent build / job metadata
.emergent/emergent.yml

# Generic credential files
credentials.json
*.pem
*.key
*.crt
.credentials

# Logs
*.log
logs/

# Database dumps
*.bson
*.json.gz
dump/

# Webpack / CRA caches
frontend/node_modules/
frontend/build/
frontend/.cache/
**/.cache/
**/node_modules/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Secrets — never commit (iter D-82c)
.jwt_secret
*.scbak
.env
.env.*
*.env
